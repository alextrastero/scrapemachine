# Email configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Booking automation (Sporttia)
BOOKING_WINDOW_DAYS=7
BOOKING_RELEASE_HOUR=9
SPORTTIA_USER_ID=your-sporttia-user-id
SPORTTIA_USER_NAME=Your Full Name
SPORTTIA_LOGIN=your-sporttia-login
SPORTTIA_PASSWORD=your-sporttia-password
# Fallback only, used if SPORTTIA_LOGIN/SPORTTIA_PASSWORD aren't set:
SPORTTIA_SESSION_TOKEN=your-play-session-token-cookie-value
